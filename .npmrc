# next-on-pages mensyaratkan peer "next>=14.3.0" di package.json-nya, padahal versi
# Next.js 14.2.x (yang dipakai proyek ini) tetap kompatibel dengan next-on-pages.
# legacy-peer-deps menonaktifkan pengecekan peer dependency yang terlalu ketat ini,
# supaya `npm install` tidak gagal karena ERESOLVE.
legacy-peer-deps=true
